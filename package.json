{
  "name": "mail-mgr",
  "version": "1.0.0",
  "description": "Email rule engine with IMAP support",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc && node esbuild.mjs",
    "build:frontend": "node esbuild.mjs",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:acceptance": "vitest run --config vitest.acceptance.config.ts",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "better-sqlite3": "^12.6.2",
    "fastify": "^5.7.4",
    "imapflow": "^1.2.8",
    "picomatch": "^4.0.3",
    "pino": "^10.3.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.0",
    "@types/nodemailer": "^7.0.11",
    "@types/picomatch": "^4.0.2",
    "esbuild": "^0.27.2",
    "nodemailer": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
